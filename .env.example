PORT=3000

# Zendesk configuration
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=agent@example.com
ZENDESK_API_TOKEN=your-zendesk-api-token
ZENDESK_WEBHOOK_TOKEN=your-zendesk-webhook-token

# OpenRouter / OpenAI SDK configuration
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.5-flash

# Optional headers recommended by OpenRouter
OPENROUTER_SITE_URL=https://your-site.example.com
OPENROUTER_SITE_NAME=Antikvarijat Libar Middleware Bot
EMBED_ALLOWED_ORIGINS=

# Optional RAG tuning
HELP_CENTER_CACHE_TTL_MS=300000
HELP_CENTER_CONTEXT_ARTICLES=5
KNOWLEDGE_CONTEXT_ITEMS=5
KNOWLEDGE_MIN_TOP_SCORE=5
ENABLE_EMAIL_SPAM_CLASSIFIER=true
EMAIL_SPAM_AI_MIN_CONFIDENCE=0.75

# Optional OneDrive / Microsoft Graph knowledge source
ONEDRIVE_TENANT_ID=
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_DRIVE_ID=
ONEDRIVE_SITE_ID=
ONEDRIVE_FOLDER_ID=
ONEDRIVE_FOLDER_URL=
ONEDRIVE_CACHE_TTL_MS=300000
ONEDRIVE_CONTEXT_DOCUMENTS=3
ONEDRIVE_MAX_FILE_SIZE_BYTES=2097152
